<?xml version='1.0' encoding='utf-8'?>
<widget id="com.transistorsoft.cordova.helloworld" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:android="http://schemas.android.com/apk/res/android" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>BGGeo Hello World</name>
    <description>Background Geolocation Hello World Example</description>
    <author email="chris@transistorsoft.com" href="https://transistorsoft.com">Transistor Software</author>
    <content src="index.html" />
    <preference name="StatusBarOverlaysWebView" value="false" />
    <preference name="StatusBarBackgroundColor" value="#2196F3" />
    <preference name="StatusBarStyle" value="lightcontent" />
    <platform name="ios">
        <config-file parent="TSLocationManagerLicense" target="*-Info.plist">
            <string>eyJhbGciOiJFZERTQSIsImtpZCI6ImVkMjU1MTktbWFpbi12MSJ9..EqhmjkZEU-oTXsxH0CUuM6GuNkhBhE6H7k_QzN1l0s2ATDjH8hVTfLbrMwaPWxxjkEchVN2llUGdBp6118BqDg</string>
        </config-file>

        <preference name="WKWebViewOnly" value="true" />
        <preference name="deployment-target" value="13.0" />
        <edit-config file="*-Info.plist" mode="merge" target="NSLocationAlwaysAndWhenInUseUsageDescription">
            <string>Always allow access to device location so the app can track your position in the background.</string>
        </edit-config>
        <edit-config file="*-Info.plist" mode="merge" target="NSLocationWhenInUseUsageDescription">
            <string>Allow access to device location so the app can track your position.</string>
        </edit-config>
        <edit-config file="*-Info.plist" mode="merge" target="NSMotionUsageDescription">
            <string>Motion activity is used to determine when you are walking, running, or driving.</string>
        </edit-config>
    </platform>
    <platform name="android">
        <config-file parent="/manifest/application" target="app/src/main/AndroidManifest.xml">
            <meta-data
                android:name="com.transistorsoft.locationmanager.license" android:value="eyJhbGciOiJFZERTQSIsImtpZCI6ImVkMjU1MTktbWFpbi12MSJ9..mgu0KEscXqWzpumZ2Bhyxm_1INMXEH_G_6tr1eO-eeolpvUS5HYwBH4lGwgGym8K37liBSAa8YsLkWJKHTPVAA" />
        </config-file>

        <preference name="android-minSdkVersion" value="24" />
        <preference name="android-targetSdkVersion" value="35" />
        <preference name="android-compileSdkVersion" value="36" />
    </platform>
</widget>
