<?xml version='1.0' encoding='utf-8'?>
<widget id="com.transistorsoft.cordova.helloworld" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <feature name="CDVWebViewEngine">
        <param name="ios-package" value="CDVWebViewEngine" />
    </feature>
    <feature name="LaunchScreen">
        <param name="ios-package" value="CDVLaunchScreen" />
    </feature>
    <feature name="LocalStorage">
        <param name="ios-package" value="CDVLocalStorage" />
    </feature>
    <feature name="Console">
        <param name="ios-package" value="CDVLogger" />
        <param name="onload" value="true" />
    </feature>
    <feature name="HandleOpenUrl">
        <param name="ios-package" value="CDVHandleOpenURL" />
        <param name="onload" value="true" />
    </feature>
    <feature name="IntentAndNavigationFilter">
        <param name="ios-package" value="CDVIntentAndNavigationFilter" />
        <param name="onload" value="true" />
    </feature>
    <feature name="GestureHandler">
        <param name="ios-package" value="CDVGestureHandler" />
        <param name="onload" value="true" />
    </feature>
    <feature name="StatusBarInternal">
        <param name="ios-package" value="CDVStatusBarInternal" />
        <param name="onload" value="true" />
    </feature>
    <feature name="BackgroundGeolocation">
        <param name="ios-package" value="CDVBackgroundGeolocation" />
    </feature>
    <name>BGGeo Hello World</name>
    <description>Background Geolocation Hello World Example</description>
    <author email="chris@transistorsoft.com" href="https://transistorsoft.com">Transistor Software</author>
    <content src="index.html" />
    <edit-config file="*-Info.plist" mode="merge" target="NSLocationAlwaysAndWhenInUseUsageDescription">
        <string>Always allow access to device location so the app can track your position in the background.</string>
    </edit-config>
    <edit-config file="*-Info.plist" mode="merge" target="NSLocationWhenInUseUsageDescription">
        <string>Allow access to device location so the app can track your position.</string>
    </edit-config>
    <edit-config file="*-Info.plist" mode="merge" target="NSMotionUsageDescription">
        <string>Motion activity is used to determine when you are walking, running, or driving.</string>
    </edit-config>
    <preference name="AllowInlineMediaPlayback" value="false" />
    <preference name="DisallowOverscroll" value="false" />
    <preference name="EnableViewportScale" value="false" />
    <preference name="MediaPermissionGrantType" value="grantIfSameHostElsePrompt" />
    <preference name="MediaTypesRequiringUserActionForPlayback" value="none" />
    <preference name="SuppressesIncrementalRendering" value="false" />
    <preference name="SuppressesLongPressGesture" value="false" />
    <preference name="Suppresses3DTouchGesture" value="false" />
    <preference name="StatusBarOverlaysWebView" value="false" />
    <preference name="StatusBarBackgroundColor" value="#2196F3" />
    <preference name="StatusBarStyle" value="lightcontent" />
    <preference name="WKWebViewOnly" value="true" />
    <preference name="deployment-target" value="13.0" />
</widget>
